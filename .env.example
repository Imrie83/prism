# Copy to .env and adjust if needed.
# Ollama runs on the host — docker-compose defaults to host.docker.internal:11434
# Override here if your Ollama runs on a different port or host.
OLLAMA_BASE_URL=http://host.docker.internal:11434

OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Used for email sending and bounce monitoring
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# How often to check inbox for bounces (in minutes)
BOUNCE_CHECK_INTERVAL_MINUTES=10
